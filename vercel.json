{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.0.90"
    },
    "*.php": {
      "runtime": "vercel-php@0.0.90"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/login.php",
      "dest": "/login.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}