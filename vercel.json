{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/login", "dest": "/api/login.php" },
    { "src": "/dashboard", "dest": "/api/dashboard.php" },
    { "src": "/api/(.*)", "dest": "/api/$1.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}