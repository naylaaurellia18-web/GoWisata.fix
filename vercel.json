{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "cleanUrls": true,
  "routes": [
    {
      "src": "/login.php",
      "dest": "/login.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}